# Liga dados mock (sem backend). Deixe "true" para rodar o protótipo isolado —
# nesse modo o login/cadastro aceitam qualquer credencial e o app fica navegável.
# Desligue (=false) para usar a API real (JWT) via proxy /api -> http://127.0.0.1:8000
VITE_USE_MOCK=false

# Base da API real (usada quando VITE_USE_MOCK=false; deixe em branco para usar
# o proxy /api do Vite). A autenticação é por JWT (SimpleJWT): o token é obtido
# no login e guardado no navegador — Basic auth foi removido.
# VITE_API_BASE_URL=
