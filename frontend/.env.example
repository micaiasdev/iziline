# Liga dados mock (sem backend). Deixe "true" para rodar o protótipo isolado.
# Desligue (=false) para usar a API real via proxy /api -> http://127.0.0.1:8000
VITE_USE_MOCK=true

# API real (usados quando VITE_USE_MOCK=false; deixe em branco no mock)
# VITE_API_BASE_URL=
# VITE_API_USERNAME=
# VITE_API_PASSWORD=
